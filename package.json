{
  "name": "heures-de-geo",
  "private": true,
  "version": "1.0.186",
  "type": "module",
  "scripts": {
    "dev": "node scripts/gen-build-info.mjs && vite",
    "dev:mobile-lab": "node scripts/gen-build-info.mjs && vite --host 0.0.0.0 --open /mobile-lab",
    "typecheck": "tsc --noEmit",
    "qa": "npm run typecheck && npm run test && npm run build",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node scripts/run-tests.mjs all",
    "test:watch": "node --import tsx/esm --test --watch src/tests/**/*.test.mjs",
    "test:unit": "node scripts/run-tests.mjs unit",
    "test:integration": "node scripts/run-tests.mjs integration",
    "test:e2e": "npm run migrate:check && playwright test",
    "test:b3": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:b4": "npm run test:b3",
    "test:coverage": "echo \"Coverage requires c8/nyc (not installed in this environment)\" && exit 1",
    "test:hooks": "vitest run",
    "test:hooks:watch": "vitest",
    "test:hooks:coverage": "vitest run --coverage",
    "test:all": "npm run test:unit && npm run test:hooks",
    "migrate:check": "supabase db push --dry-run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "e2e:desktop": "playwright test --project=desktop-chrome --project=desktop-firefox",
    "e2e:mobile": "playwright test --project=mobile-iphone --project=mobile-pixel",
    "e2e:chrome": "playwright test --project=desktop-chrome",
    "e2e:firefox": "playwright test --project=desktop-firefox",
    "e2e:iphone": "playwright test --project=mobile-iphone",
    "e2e:pixel": "playwright test --project=mobile-pixel",
    "e2e:ci": "playwright test --project=desktop-chrome --project=desktop-firefox",
    "e2e:visual": "playwright test --config=playwright.visual.config.ts",
    "e2e:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "e2e:visual:iphone": "playwright test --config=playwright.visual.config.ts --project=visual-iphone",
    "e2e:visual:desktop": "playwright test --config=playwright.visual.config.ts --project=visual-desktop",
    "e2e:visual:report": "playwright show-report playwright-visual-report"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@sentry/react": "^10.53.1",
    "@supabase/supabase-js": "^2.39.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "workbox-window": "^7.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.18",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tinyglobby": "^0.2.12",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  }
}
