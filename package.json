{
  "name": "heures-de-geo",
  "private": true,
  "version": "1.0.147",
  "type": "module",
  "scripts": {
    "dev": "node scripts/gen-build-info.mjs && vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node scripts/run-tests.mjs all",
    "test:watch": "node --import tsx/esm --test --watch src/tests/**/*.test.mjs",
    "test:unit": "node scripts/run-tests.mjs unit",
    "test:integration": "node scripts/run-tests.mjs integration",
    "test:e2e": "node scripts/run-tests.mjs e2e",
    "test:b3": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:b4": "npm run test:b3",
    "test:coverage": "echo \"Coverage requires c8/nyc (not installed in this environment)\" && exit 1",
    "test:hooks": "vitest run",
    "test:hooks:watch": "vitest",
    "test:hooks:coverage": "vitest run --coverage",
    "test:all": "npm run test:unit && npm run test:hooks"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "workbox-window": "^7.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.18",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tinyglobby": "^0.2.12",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  }
}
